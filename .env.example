# Bot Configuration
BOT_USERNAME=basic-ai-agent

# AI Gateway (https://vercel.com/docs/ai-gateway)
AI_GATEWAY_API_KEY=your-ai-gateway-api-key
# Optional: override the default model (anthropic/claude-sonnet-4)
# AI_MODEL=openai/gpt-4o

# State (required for production — thread subscriptions and distributed locking)
# Upstash Redis connection string (rediss://...)
REDIS_URL=rediss://default:your-password@your-host.upstash.io:6379
# If REDIS_URL is unset, the bot falls back to in-memory state (dev only).

# Web
# The Web adapter delegates browser request authentication to the getUser config function.
# Constructor config: userName, getUser, persistMessageHistory, threadIdFor

# Slack (https://chat-sdk.dev/adapters/official/slack)
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_SIGNING_SECRET=your-signing-secret

# Telegram (https://chat-sdk.dev/adapters/official/telegram)
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# TELEGRAM_WEBHOOK_SECRET_TOKEN=your-webhook-secret
# TELEGRAM_BOT_USERNAME=mybot

# WhatsApp Business Cloud (https://chat-sdk.dev/adapters/official/whatsapp)
# WHATSAPP_ACCESS_TOKEN=your-access-token
# WHATSAPP_APP_SECRET=your-app-secret
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_VERIFY_TOKEN=your-verify-token

# Google Chat (https://chat-sdk.dev/adapters/official/gchat)
# GOOGLE_CHAT_CREDENTIALS={"type":"service_account",...}
# GOOGLE_CHAT_PROJECT_NUMBER=123456789
# Optional — receive all space messages (not just @mentions):
# GOOGLE_CHAT_PUBSUB_TOPIC=projects/your-project/topics/chat-events
# GOOGLE_CHAT_IMPERSONATE_USER=admin@yourdomain.com
# GOOGLE_CHAT_PUBSUB_AUDIENCE=https://your-domain.com/api/webhooks/gchat
# Or use Application Default Credentials instead of service account JSON:
# GOOGLE_CHAT_USE_ADC=true

# GitHub (https://chat-sdk.dev/adapters/official/github)
# Option A — Personal Access Token (simplest for personal repos):
# GITHUB_TOKEN=ghp_your-personal-access-token
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
# GITHUB_BOT_USERNAME=your-github-username

# Option B — GitHub App (recommended for production):
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
# GITHUB_BOT_USERNAME=your-app-name[bot]
# GITHUB_INSTALLATION_ID=12345678
# Optional: numeric bot user id to avoid self-reply loops on serverless
# GITHUB_BOT_USER_ID=12345678
