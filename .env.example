# Bot Configuration
BOT_USERNAME=basic-ai-agent

# AI Gateway (https://vercel.com/docs/ai-gateway)
AI_GATEWAY_API_KEY=your-ai-gateway-api-key
# Optional: override the default model (anthropic/claude-sonnet-4)
# AI_MODEL=openai/gpt-4o

# Web search (optional — enables the researcher subagent's search_web tool)
# TAVILY_API_KEY=tvly-your-tavily-api-key

# State (required for production — thread subscriptions and distributed locking)
# Upstash Redis connection string (rediss://...)
REDIS_URL=rediss://default:your-password@your-host.upstash.io:6379
# If REDIS_URL is unset, the bot falls back to in-memory state (dev only).

# Web
# Browser chat uses the eve HTTP channel at /eve/v1/session via useEveAgent.
# Platform messengers use the eve Chat SDK channel at /api/webhooks/{platform}.
# Connector status dashboard: http://localhost:3000/settings
# Requires Node 24+ (see package.json engines).

# Slack (https://chat-sdk.dev/adapters/official/slack)
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_SIGNING_SECRET=your-signing-secret

# Telegram (https://chat-sdk.dev/adapters/official/telegram)
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# TELEGRAM_WEBHOOK_SECRET_TOKEN=your-webhook-secret
# TELEGRAM_BOT_USERNAME=mybot

# WhatsApp Business Cloud (https://chat-sdk.dev/adapters/official/whatsapp)
# WHATSAPP_ACCESS_TOKEN=your-access-token
# WHATSAPP_APP_SECRET=your-app-secret
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_VERIFY_TOKEN=your-verify-token

# Google Chat (https://chat-sdk.dev/adapters/official/gchat)
# GOOGLE_CHAT_CREDENTIALS={"type":"service_account",...}
# GOOGLE_CHAT_PROJECT_NUMBER=123456789
# Optional — receive all space messages (not just @mentions):
# GOOGLE_CHAT_PUBSUB_TOPIC=projects/your-project/topics/chat-events
# GOOGLE_CHAT_IMPERSONATE_USER=admin@yourdomain.com
# GOOGLE_CHAT_PUBSUB_AUDIENCE=https://your-domain.com/api/webhooks/gchat
# Or use Application Default Credentials instead of service account JSON:
# GOOGLE_CHAT_USE_ADC=true

# GitHub (https://chat-sdk.dev/adapters/official/github)
# Option A — Personal Access Token (simplest for personal repos):
# GITHUB_TOKEN=ghp_your-personal-access-token
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
# GITHUB_BOT_USERNAME=your-github-username

# Option B — GitHub App (recommended for production):
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
# GITHUB_BOT_USERNAME=your-app-name[bot]
# GITHUB_INSTALLATION_ID=12345678
# Optional: numeric bot user id to avoid self-reply loops on serverless
# GITHUB_BOT_USER_ID=12345678

# Sendblue (https://chat-sdk.dev/adapters/vendor-official/sendblue)
# SENDBLUE_API_KEY=your-api-key-id
# SENDBLUE_API_SECRET=your-api-secret
# SENDBLUE_FROM_NUMBER=+15551234567
# Optional:
# SENDBLUE_WEBHOOK_SECRET=your-webhook-secret
# SENDBLUE_STATUS_CALLBACK_URL=https://your-domain.com/api/webhooks/sendblue/status

# Discord (https://chat-sdk.dev/adapters/official/discord)
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_PUBLIC_KEY=your-application-public-key
# DISCORD_APPLICATION_ID=your-application-id
# Optional:
# DISCORD_MENTION_ROLE_IDS=role-id-1,role-id-2

# Microsoft Teams (https://chat-sdk.dev/adapters/official/teams)
# TEAMS_APP_ID=your-azure-bot-app-id
# TEAMS_APP_PASSWORD=your-azure-bot-app-password
# Optional:
# TEAMS_APP_TENANT_ID=your-tenant-id

# Linear (https://chat-sdk.dev/adapters/official/linear)
# LINEAR_API_KEY=lin_api_your-personal-api-key
# LINEAR_WEBHOOK_SECRET=your-webhook-signing-secret
# Optional:
# LINEAR_BOT_USERNAME=my-linear-bot
# LINEAR_MODE=agent-sessions

# Facebook Messenger (https://chat-sdk.dev/adapters/official/messenger)
# FACEBOOK_APP_SECRET=your-app-secret
# FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token
# FACEBOOK_VERIFY_TOKEN=your-webhook-verify-token
# Optional:
# FACEBOOK_BOT_USERNAME=my-page-bot

# X / Twitter (https://chat-sdk.dev/adapters/official/x)
# X_CONSUMER_SECRET=your-api-key-secret
# Option A — static access token (~2h expiry):
# X_USER_ACCESS_TOKEN=your-oauth2-user-access-token
# Option B — managed OAuth refresh (recommended for production; requires REDIS_URL):
# X_CLIENT_ID=your-oauth2-client-id
# X_REFRESH_TOKEN=your-oauth2-refresh-token
# Optional:
# X_CLIENT_SECRET=your-oauth2-client-secret
# X_ENCRYPTION_KEY=base64-32-byte-aes-key-for-stored-tokens
# X_USER_ID=your-bot-user-id
# X_USERNAME=your-bot-handle

# Resend email (https://chat-sdk.dev/adapters/vendor-official/resend)
# RESEND_API_KEY=re_your-resend-api-key
# RESEND_WEBHOOK_SECRET=whsec_your-webhook-secret
# RESEND_FROM_ADDRESS=bot@yourdomain.com
# Optional:
# RESEND_FROM_NAME=My Bot

# Grok Voice (Railway proxy — deploy services/voice-proxy/ to a NEW Railway project)
# Never reuse or modify the fieldflow service at voice.tradecraft.nexus.
# XAI_API_KEY=your-xai-api-key
# NEXT_PUBLIC_VOICE_PROXY_URL=https://your-voice-proxy.up.railway.app
# VOICE_PROXY_SHARED_SECRET=generate-a-new-random-secret
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
# XAI_REALTIME_MODEL=grok-voice-think-fast-1.0
# Optional Redis for voice-proxy connection limits:
# KV_REST_API_URL=https://your-upstash.upstash.io
# KV_REST_API_TOKEN=your-upstash-token
